{
  "name": "WebLingo Marketin Website",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "volta": {
    "node": "20.11.1",
    "pnpm": "9.12.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "type": "node scripts/ensure-next-types.cjs && tsc --noEmit",
    "typecheck": "pnpm run type",
    "test": "vitest run",
    "test:contracts": "vitest run internal/dashboard/webhooks.openapi-contract.test.ts internal/dashboard/webhooks.timeout.test.ts app/dashboard/sites/[id]/history/page.webhooks-contract.test.tsx tests/docs/docs-feature-coverage.test.ts tests/docs/docs-env-contract.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "CI=1 DASHBOARD_E2E_MOCK=1 playwright test tests/smoke/dashboard.smoke.spec.ts",
    "test:e2e:preview-ui": "playwright test tests/preview-ui/preview-flow.spec.ts",
    "test:e2e:preview-live": "playwright test tests/preview-live/translated-preview-runtime.spec.ts",
    "test:showcase:fixtures": "playwright test tests/showcase-fixtures.spec.ts tests/customer-seo-fixtures.spec.ts",
    "test:showcase:fixtures:production": "pnpm run build && PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001 playwright test --config playwright.production.config.ts tests/showcase-fixtures.spec.ts tests/customer-seo-fixtures.spec.ts",
    "premerge:preview-ux": "node scripts/premerge-preview-ux.mjs",
    "docs:sync:tsc": "tsc --pretty false --noEmit false --skipLibCheck true --types node --module commonjs --moduleResolution node --target ES2022 --outDir .tmp/docs-sync scripts/docs-sync-shared.ts scripts/docs-sync-weblingo.ts scripts/docs-sync-check.ts",
    "docs:sync": "pnpm docs:sync:tsc && node .tmp/docs-sync/docs-sync-weblingo.js",
    "docs:sync:check": "pnpm docs:sync:tsc && node .tmp/docs-sync/docs-sync-check.js",
    "check": "pnpm run lint && pnpm run format && pnpm run type",
    "check:ci": "pnpm run lint && pnpm run format && pnpm run type && pnpm run test:contracts && node scripts/check-ci.mjs",
    "supabase:types": "supabase gen types typescript --schema public --project-id \"$SUPABASE_PROJECT_ID\" > types/database.ts"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@next/mdx": "16.2.6",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.1.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.105.4",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "core-js": "3",
    "lucide-react": "^0.562.0",
    "mobx": "6",
    "next": "16.2.6",
    "posthog-js": "^1.376.1",
    "posthog-node": "^4.18.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "redoc": "2.5.2",
    "sonner": "^2.0.7",
    "stripe": "^22.0.2",
    "styled-components": "6",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "baseline-browser-mapping": "^2.10.18",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.6",
    "happy-dom": "^20.3.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.60.1",
    "vite": "7.3.5",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "glob@10.4.5": "10.5.0",
      "js-yaml@4.1.0": "4.1.1",
      "preact@10.27.2": "10.27.3",
      "minimatch": "10.2.3",
      "rollup": "4.59.0",
      "ajv": "6.14.0",
      "qs": "6.14.2",
      "flatted": "3.4.2",
      "protobufjs": "7.6.1",
      "fast-uri": "3.1.2",
      "fast-xml-builder": "1.2.0",
      "fast-xml-parser": "5.5.10",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.4",
      "happy-dom": "20.8.9",
      "esbuild": "0.28.1",
      "vite": "7.3.5",
      "vite@7.3.2": "7.3.5",
      "form-data": "4.0.6",
      "ws@8.19.0": "8.21.0"
    }
  }
}
